# Neon database connection string
# Example: postgresql://USER:PASSWORD@ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Shared passphrase required to register a new account. Anyone with the site
# link but without this value cannot create an account. Set this to something
# only you know, then use it once when registering your own account.
REGISTRATION_SECRET=WE SHALL NOT BE FOUND WANTING

